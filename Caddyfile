# eOffice edge. SITE_ADDRESS controls TLS:
#   - a bare domain (e.g. eoffice.example.com) → Caddy auto-provisions a Let's Encrypt cert
#   - ":80"                                     → plain HTTP (internal / behind another proxy)
{$SITE_ADDRESS} {
	encode gzip zstd

	# API → backend container. The full /api/v1/... path is forwarded unchanged.
	handle /api/* {
		reverse_proxy api:4000
	}

	# SPA static assets with client-side-routing fallback to index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	# Uploaded documents are served by the API from S3 — never from the web tier.
}
