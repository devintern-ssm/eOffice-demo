// e-Office N-C File System — data model (NOTE-CENTRIC)
// Redesign baseline: docs/12_note_centric_redesign.md
// The unit of workflow is the NOTE, not the file. A File is a permanent binder (UN number)
// that accumulates notes + correspondence and normally never closes. Each Note has its own
// maker and its own signature chain (NoteStep[]); notes are strictly sequential.
// NOTE: SQLite (dev) does not support Prisma enums, so status/role fields are String with the
// allowed values documented inline; they are validated in the app layer (zod) and become
// native Postgres enums when DATABASE_URL is switched to Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & roles
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(uuid())
  name         String
  designation  String
  section      String
  role         String   @default("MAKER") // MAKER | CHECKER | APPROVER | MD | ADMIN
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  createdFiles  File[]         @relation("FileCreatedBy")
  heldFiles     File[]         @relation("FileHolder")
  notes         Note[]
  noteSteps     NoteStep[]
  notifications Notification[]
}

// ---------------------------------------------------------------------------
// File — the permanent N-C binder. UUID PK + DEPT/YEAR/SEQ display no. assigned at CREATE.
// status is just OPEN | CLOSED — "approval" happens per note, not on the file.
// ---------------------------------------------------------------------------
model File {
  id               String    @id @default(uuid())
  displayNumber    String?   @unique // DEPT/YEAR/SEQ e.g. ACC/2026/001 — the UN number (assigned at create)
  customFileNumber String?           // optional user-entered label
  subject          String            // purpose/grouping of the binder
  section          String            // current physical location (department)
  status           String    @default("OPEN") // OPEN | CLOSED
  priority         String    @default("Normal") // Normal|High|Urgent
  confidential     Boolean   @default(false)
  startPeriod      DateTime?
  endPeriod        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  createdById     String
  createdBy       User      @relation("FileCreatedBy", fields: [createdById], references: [id])
  currentHolderId String?           // the single-holder lock — always present while OPEN
  currentHolder   User?     @relation("FileHolder", fields: [currentHolderId], references: [id])

  // Closure + successor linkage (rare — a "case" file closed at the end)
  closeDate       DateTime?
  closeReason     String?
  successorFileId String?   @unique
  successorFile   File?     @relation("FileSuccessor", fields: [successorFileId], references: [id])
  predecessorFile File?     @relation("FileSuccessor")

  notes           Note[]
  correspondence  Correspondence[]
  noteSteps       NoteStep[]
  movements       Movement[]
  notifications   Notification[]

  @@index([section])
  @@index([status])
  @@index([createdById])
  @@index([currentHolderId])
}

// ---------------------------------------------------------------------------
// Noting side — each Note is a mini approval process with its OWN maker + chain.
// ---------------------------------------------------------------------------
model Note {
  id          String   @id @default(uuid())
  fileId      String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  noteNumber  Int              // per-file sequence (1,2,3…) — continuous across the binder's life
  content     String
  authorId    String           // the NOTE'S MAKER
  author      User     @relation(fields: [authorId], references: [id])
  authorName  String           // denormalized for immutable audit
  authorRole  String           // MAKER | CHECKER | APPROVER | MD (the maker's role at the time)
  // Per-note lifecycle: DRAFT (maker editing) → IN_REVIEW (moving through signers)
  //  → RETURNED (sent back to maker, editable again) → FINALIZED (fully signed, "ended").
  status      String   @default("DRAFT") // DRAFT | IN_REVIEW | RETURNED | FINALIZED
  isSuoMoto   Boolean  @default(false)    // note raised without a triggering correspondence
  createdAt   DateTime @default(now())
  submittedAt DateTime?
  finalizedAt DateTime?

  references         NoteReference[]
  steps              NoteStep[]           // the note's signature chain
  paragraphApprovals ParagraphApproval[]
  checkerComments    CheckerComment[]

  @@unique([fileId, noteNumber])
  @@index([fileId])
  @@index([status])
}

model NoteReference {
  id         String @id @default(uuid())
  noteId     String
  note       Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  targetType String // CORRESPONDENCE | NOTE
  targetRef  String // page-level "C3" (correspondence) or "Note 1"
}

// A note (or a paragraph within it) can be pre-assigned to a specific approver — optional label
// layer on top of the note chain (kept for annotation; the NoteStep chain is authoritative).
model ParagraphApproval {
  id            String   @id @default(uuid())
  noteId        String
  note          Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  paragraphMark String   // 'A', 'B', … or '—' for the whole note
  role           String  @default("APPROVER") // CHECKER | APPROVER
  status         String  @default("APPROVED") // PENDING | APPROVED
  assignedToId   String?
  assignedToName String?
  approvedById   String?
  approvedByName String?
  approvedAt    DateTime @default(now())
}

// Comments after a note is finalized — append-only.
model CheckerComment {
  id         String   @id @default(uuid())
  noteId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  comment    String
  action     String   @default("comment") // comment | signed | returned
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Correspondence side — multi-format attachments. Each attachment occupies a contiguous run
// of page-level C-numbers (C1…Cn); the run is DERIVED from pageCount ordering at read time.
// ---------------------------------------------------------------------------
model Correspondence {
  id           String   @id @default(uuid())
  fileId       String
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  number       String   // internal attachment index label ("C/1") — display uses the derived C-range
  seq          Int      @default(0) // attachment order within the file (drives C-range derivation)
  type         String
  title        String
  inwardDate   DateTime?
  inwardNumber String?
  storageKey   String?          // path in the StorageProvider
  mime         String   @default("application/pdf")
  originalName String?          // original upload filename (multi-format download)
  pageCount    Int?             // pages in the attachment — drives page-level C-numbering
  uploadedById String
  uploadedByName String
  createdAt    DateTime @default(now())

  accesses     CorrespondenceAccess[]

  @@unique([fileId, number])
  @@index([fileId])
}

// ---------------------------------------------------------------------------
// Correspondence access log — who viewed/downloaded which document, and when.
// ---------------------------------------------------------------------------
model CorrespondenceAccess {
  id               String        @id @default(uuid())
  correspondenceId String
  correspondence   Correspondence @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)
  fileId           String
  userId           String
  userName         String
  action           String        // DOWNLOAD | VIEW
  createdAt        DateTime      @default(now())

  @@index([correspondenceId])
  @@index([fileId])
}

// ---------------------------------------------------------------------------
// NoteStep — the note's sequential signature chain (was the file-level WorkflowStep).
// The active step = the first PENDING; its signer holds the file. Two actions: SIGNED / RETURNED.
// ---------------------------------------------------------------------------
model NoteStep {
  id            String    @id @default(uuid())
  noteId        String
  note          Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  fileId        String              // denormalized for convenient file-scoped queries
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  stepOrder     Int                 // strict sequence within the note
  signerId      String
  signer        User      @relation(fields: [signerId], references: [id])
  signerName    String
  roleLabel     String    @default("Signatory") // display-only (Checker/Approver/MD/…)
  status        String    @default("PENDING")   // PENDING | SIGNED | RETURNED
  remarks       String?
  dept          String?             // records the acting department
  signatureName String?             // typed-name signature
  actedAt       DateTime?
  createdAt     DateTime  @default(now())

  @@unique([noteId, stepOrder])
  @@index([noteId])
  @@index([fileId])
  @@index([signerId])
}

// ---------------------------------------------------------------------------
// Movement / audit — append-only; every state change writes one.
// ---------------------------------------------------------------------------
model Movement {
  id          String   @id @default(uuid())
  fileId      String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  type        String   // CREATE|OPEN_NOTE|SUBMIT_NOTE|SIGN|RETURN_NOTE|FINALIZE|HANDOVER|TRANSFER|CLOSE|UPLOAD|NOTE_ADDED|ASSIGN
  actorId     String
  actorName   String
  fromUserId  String?
  fromName    String?
  toUserId    String?
  toName      String?
  fromSection String?
  toSection   String?
  dept        String?
  noteNumber  Int?             // which note this movement relates to (if any)
  remarks     String?
  createdAt   DateTime @default(now())

  @@index([fileId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// In-app notifications — one row per recipient per event.
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // OPEN_NOTE | SIGN | RETURN | FINALIZE | HANDOVER | ASSIGN | COMMENT
  message   String
  fileId    String?
  file      File?    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Departments / sections — admin-manageable. `code` feeds DEPT/YEAR/SEQ; `name` shows on files.
// ---------------------------------------------------------------------------
model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   // short code used in file numbers (e.g. ADMIN, ACC)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Per (department, year) sequence allocator for DEPT/YEAR/SEQ numbers.
// ---------------------------------------------------------------------------
model NumberSequence {
  id       String @id @default(uuid())
  deptCode String
  year     Int
  lastSeq  Int    @default(0)

  @@unique([deptCode, year])
}
