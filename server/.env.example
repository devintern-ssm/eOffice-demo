# Copy to .env and adjust. SQLite for local dev; swap DATABASE_URL to Postgres for prod.
DATABASE_URL="file:./dev.db"
PORT=4000
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="1d"
# Comma-separated origins allowed by CORS (the Vite dev server):
CORS_ORIGIN="http://localhost:3000"
# Local disk root for PDF correspondence uploads (Phase 1):
UPLOAD_DIR="./uploads"
