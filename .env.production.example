# Copy to `.env` (same directory as docker-compose.yml) and fill in real values.
# docker compose reads `.env` automatically.

# ── Domain / TLS ───────────────────────────────────────────────────────────
# Bare domain → Caddy auto-provisions a Let's Encrypt certificate (ports 80+443
# must be reachable from the internet and DNS must already point here).
# Use ":80" for plain HTTP (internal pilot / behind another proxy).
SITE_ADDRESS=eoffice.example.com
CORS_ORIGIN=https://eoffice.example.com

# ── Auth ───────────────────────────────────────────────────────────────────
# Use a long random string, e.g.  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=1d

# ── MinIO (S3) object store for documents ────────────────────────────────────
MINIO_ROOT_USER=eoffice-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
S3_BUCKET=eoffice

# ── First-boot seeding ───────────────────────────────────────────────────────
# Seeds demo users with the well-known password "password123" — for a throwaway
# pilot only. Set true for the FIRST `up`, then set back to false and change
# passwords. Leave false for a real deployment and create the admin manually.
SEED_ON_START=false
